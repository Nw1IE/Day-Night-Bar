# Ключ для JWT-токена админки (должен быть длинным и случайным в проде)
JWT_KEY=ChangeMeToALongRandomSecretKeyPlease123!
JWT_ISSUER=MyAwesomeServer
JWT_AUDIENCE=MyAwesomeClient

# Секрет, который клиент должен прислать в заголовке X-Admin-Client-Key при логине.
# Должен совпадать с VITE_ADMIN_CLIENT_KEY на фронте (client/.env)
ADMIN_CLIENT_KEY=1

# Через запятую, без пробелов, если несколько
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Путь входа админки: /api/auth/{AUTH_GATEWAY_PATH}
AUTH_GATEWAY_PATH=login
